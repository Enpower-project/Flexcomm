# ============================================================
# SCOT Backend — Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# ============================================================


# ── Database ─────────────────────────────────────────────────────────────────

# When running locally (scripts or uvicorn outside Docker):
DATABASE_URL=postgresql://username:password@host:5432/dbname

# When running FastAPI inside Docker on the same network as enpower_postgres:
# DATABASE_URL=postgresql://**:**@enpower_postgres:5432/scot_final


# ── API Keys ──────────────────────────────────────────────────────────────────

# Chalki (GR pilot) external data API key
API_KEY=your_api_key_here

# GR pilot — Siemens Energy API (Auth0 client credentials)
SIEMENS_CLIENT_ID=**
SIEMENS_CLIENT_SECRET=**

# GR pilot — Siemens API tenant and data-point identifiers
SIEMENS_PARTITION_ID=**
SIEMENS_DP_PV_PROD=**
SIEMENS_DP_PV_DELIVERY=**
SIEMENS_DP_MESI_TASI_IMPORT=**
SIEMENS_DP_MESI_TASI_EXPORT=**

# GR pilot — residential site display names (kept out of the repo)
GR_SITE_3_NAME=**
GR_SITE_4_NAME=**

# GR pilot — Meteogen forecast API login
METEOGEN_USERNAME=**
METEOGEN_PASSWORD=**


# ── GR Pilot — Chalki Island sensor UUIDs ────────────────────────────────────
# Temperature (tin) and relative-humidity (rh) sensors per site:

Dimarxeio_sunedriaston_tin=<uuid>
Dimarxeio_sunedriaston_rh=<uuid>

Dimarxeio_rack_tin=<uuid>
Dimarxeio_rack_rh=<uuid>

gr_site_3_tin=<uuid>
gr_site_3_rh=<uuid>

gr_site_4_tin=<uuid>
gr_site_4_rh=<uuid>

Super_market_tin=<uuid>
Super_market_rh=<uuid>

Cafeteria_tin=<uuid>
Cafeteria_rh=<uuid>

# Energy / consumption sensors:
Cafeteria_consumption=<uuid>
Dimarxeio_sunedriaston_consumption=<uuid>
Hotel_consumption=<uuid>
Osmosi_consumption=<uuid>


# ── HU Pilot — Békéscsaba sensor UUIDs ───────────────────────────────────────
# Residential and commercial sites (sensor_id_1..9) + weather sensor:

sensor_id_1=<uuid>
sensor_id_2=<uuid>
sensor_id_3=<uuid>
sensor_id_4=<uuid>
sensor_id_5=<uuid>
sensor_id_6=<uuid>
sensor_id_7=<uuid>
sensor_id_8=<uuid>
sensor_id_9=<uuid>
sensor_id_weather=<uuid>


# ── MinIO (S3-compatible object store) ───────────────────────────────────────

HOST_URL=http://localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=**
MINIO_SECRET_KEY=**
MINIO_ROOT_USER=**
MINIO_ROOT_PASSWORD=**
BUCKET_NAME=mlflow-bucket


# ── MLflow ───────────────────────────────────────────────────────────────────

# When FastAPI runs locally and MLflow runs in Docker:
MLFLOW_TRACKING_URI=http://localhost:5000

# When FastAPI runs inside Docker on the same network as mlflow_server:
# MLFLOW_TRACKING_URI=http://mlflow_server:5000

MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_EXPERIMENT_NAME=scot-hvac-training

# MLflow uses these to authenticate with MinIO as its artifact store:
AWS_ACCESS_KEY_ID=**
AWS_SECRET_ACCESS_KEY=**


# ── MLflow-MinIO stack PostgreSQL (pgdb container) ───────────────────────────
# Used by the mlflow_server container, NOT the application database.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=**
POSTGRES_DATABASE=postgres


# ── Application PostgreSQL (enpower_postgres container) ──────────────────────

ENPOWER_HOST=enpower_postgres
ENPOWER_USER=**
ENPOWER_PASS=**
ENPOWER_DB=enpower


# ── Dev-only flags (dangerous — disable in production) ───────────────────────

# RESET_DB_ON_STARTUP=true
# CREATE_PARQUETS_ON_STARTUP=true
