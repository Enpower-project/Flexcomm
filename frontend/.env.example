# Copy this file to .env.development and .env.production and fill in your values.
# All variables must be prefixed with REACT_APP_ to be available in the browser bundle.

# Keycloak
REACT_APP_KEYCLOAK_URL=https://your-keycloak-server.example.com
REACT_APP_KEYCLOAK_REALM=your-realm
REACT_APP_KEYCLOAK_CLIENT_ID=your-client-id

# Backend API
REACT_APP_API_BASE_URL=https://your-api-server.example.com

# Siemens Energy API (Auth0 client credentials)
REACT_APP_SIEMENS_CLIENT_ID=your-siemens-client-id
REACT_APP_SIEMENS_CLIENT_SECRET=your-siemens-client-secret
REACT_APP_SIEMENS_AUTH_URL=https://siemens-bt-015.eu.auth0.com/oauth/token
REACT_APP_SIEMENS_AUDIENCE=https://horizon.siemens.com
REACT_APP_SIEMENS_BASE_URL=https://api.bpcloud.siemens.com/energy/v1
REACT_APP_SIEMENS_PARTITION_ID=your-partition-id
REACT_APP_SIEMENS_CONSUMPTION_MEDIUM_ID=your-consumption-medium-id
